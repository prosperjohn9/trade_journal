# The deployed app the worker calls back into.
APP_URL=https://tradershindsight.com

# Shared secret. Must match WORKER_SECRET set in the app (Vercel).
WORKER_SECRET=

# MetaApi app token (the same token the app uses). Lets the worker poll
# positions and keep guarded accounts deployed.
METAAPI_TOKEN=

# Optional tuning (seconds).
POLL_INTERVAL_SECONDS=12
REFRESH_ACCOUNTS_SECONDS=120
MODIFY_COOLDOWN_SECONDS=300
NEWS_SWEEP_SECONDS=60
